# =============================================================================
# Hackathon 2026 – Variables d'environnement
# Intégration avec le code du groupe AdminDocs
# Copier ce fichier en .env : cp .env.example .env
# =============================================================================

# ---------- Airflow ----------
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=hackathon2026secretkey
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=False

# ---------- Postgres (pour Airflow) ----------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ---------- MinIO (cohérent avec branche 1-featureinit-docker) ----------
MINIO_ROOT_USER=minio_user
MINIO_ROOT_PASSWORD=minio_password
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_user
MINIO_SECRET_KEY=minio_password

# ---------- Buckets MinIO (Data Lake) ----------
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_CLEAN=clean
MINIO_BUCKET_CURATED=curated

# ---------- Services (URLs internes Docker) ----------
OCR_SERVICE_URL=http://ocr-service:8000
ANOMALY_SERVICE_URL=http://anomaly-service:8002
BUSINESS_SERVICE_URL=http://business-service:8003
BACKEND_URL=http://team-backend:4000

# ---------- OCR / Gemini (clé API à renseigner) ----------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
